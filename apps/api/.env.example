# API server port
PORT=3001

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Database connection URLs
DATABASE_URL_API=postgres://app_api:app_api_dev@localhost:5432/eventform
DATABASE_URL=postgres://eventform:eventform@localhost:5432/eventform

# Authentication mode: "dev" uses Bearer dev_<sub> tokens; "cognito" validates Cognito JWTs
AUTH_MODE=dev

# AWS KMS for endpoint secret encryption (LocalStack in dev)
KMS_KEY_ID=alias/eventform-endpoint-secrets
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1

# Rate limiting
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
PUBLIC_SUBMIT_THROTTLE_LIMIT=10
