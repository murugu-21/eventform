# Tunnel mode: TLS terminates at Cloudflare's edge; cloudflared delivers
# requests to Caddy over the compose network on plain :80. Caddy is the
# internal host-based router (static SPA + API proxy). No ACME, no open ports.
{
  auto_https off
}

http://{$WEB_HOST:eventform.murugappan.dev} {
  root * /srv/web
  encode gzip
  try_files {path} /index.html
  file_server
}

http://{$API_HOST:eventform-api.murugappan.dev} {
  reverse_proxy api:3001
}
