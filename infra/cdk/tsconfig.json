{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "noEmitOnError": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "bin",
    "lib",
    "test"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "cdk.out"
  ]
}
