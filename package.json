{
  "name": "eventform",
  "private": true,
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:up": "infra/compose/ensure-dev-key-material.sh && docker compose -f infra/compose/docker-compose.yml up -d --wait",
    "db:down": "docker compose -f infra/compose/docker-compose.yml down",
    "db:migrate": "pnpm --filter @eventform/db migrate",
    "connect:register": "infra/compose/connect/register-connector.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "@swc/core"]
  }
}
